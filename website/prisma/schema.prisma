generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model DocSection {
  id     Int       @id @default(autoincrement())
  index  Int       @unique
  title  String
  slug   String    @unique
  pages  DocPage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocPage {
  id                        Int        @id @default(autoincrement())
  sectionId                 Int
  section                   DocSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  index                     Int
  filename                  String
  name                      String
  title                     String
  description               String?
  slug                      String     @unique
  filepath                  String     @unique
  content                   String
  mdxContent                String
  mdxFrontmatterDescription String?
  headings                  String
  searchText                String
  contentHash               String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sectionId, filename])
  @@index([title])
  @@index([description])
}
