{
	"name": "dreamy-ui-website",
	"version": "0.0.2",
	"private": true,
	"sideEffects": false,
	"type": "module",
	"scripts": {
		"postinstall": "prisma generate",
		"build": "prisma generate && prisma migrate deploy && panda codegen && react-router build",
		"build:production": "prisma generate && prisma migrate deploy && panda codegen && react-router build",
		"dev": "cross-env NODE_ENV=development tsx --env-file .env app/server.dev.ts",
		"start": "cross-env NODE_ENV=production node --env-file .env ./build/server/index2.js",
		"typecheck": "react-router typegen && tsc",
		"db:migrate": "prisma migrate deploy",
		"db:migrate:dev": "prisma migrate dev",
		"docs:sync": "tsx app/scripts/sync-docs.ts",
		"compositions:host": "tsx reserve-compositions-host/server.ts",
		"test": "tsx tests/render.test.tsx",
		"test:e2e": "playwright test",
		"story": "storybook dev -p 6006"
	},
	"dependencies": {
		"@dreamy-ui/panda-preset": "workspace:*",
