# Copy this file to .env and fill in your values before running docker compose.

# ─── Required ─────────────────────────────────────────────────────────────────

# GitHub personal access token.
# Increases the GitHub API rate limit from 60 req/hr to 1000 req/hr.
# Create one at https://github.com/settings/tokens (no special scopes needed for public repos).
GITHUB_TOKEN=ghp_your_token_here

# The GitHub repo that docs are fetched from (owner/repo format).
# This value is also baked into the client bundle at build time by Vite.
VITE_SOURCE_REPO=dreamy-ui/dreamy-ui

# ─── Optional ─────────────────────────────────────────────────────────────────

# Host port that the website is exposed on (default: 3000).
PORT=3000

# Redis connection URL.
# When omitted, the server falls back to an in-memory LRU cache.
# Recommended for production multi-worker deployments (one worker per CPU core).
# Use redis://redis:6379 when running with: docker compose --profile redis up
REDIS_URL=
