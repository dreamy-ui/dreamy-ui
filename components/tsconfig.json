{
	"include": [
		"*/index.tsx",
		"*/**/*.ts",
		"*/**/*.test.tsx",
		"*/**/*.test-d.tsx",
		"scripts/**/*",
		"test/**/*"
	],
	"exclude": ["**/*.stories.tsx"],
	"compilerOptions": {
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"types": ["node", "vitest/globals", "@testing-library/jest-dom"],
		"isolatedModules": true,
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"resolveJsonModule": true,
		"target": "ES2022",
		"strict": true,
		"allowJs": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true,
		"paths": {
			"styled-system/*": ["../website/styled-system/*"],
			"@dreamy-ui/react": ["../packages/react/src/index.ts"],
			"@dreamy-ui/react/rsc": ["../packages/react/src/rsc.ts"],
			"@/*": ["../packages/react/src/*"]
		}
	}
}
