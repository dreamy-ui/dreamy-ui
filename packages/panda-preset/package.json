{
	"name": "@dreamy-ui/panda-preset",
	"version": "2.1.4",
	"description": "A panda preset for Dreamy UI React component library",
	"type": "module",
	"keywords": [
		"ui",
		"panda",
		"panda-css",
		"panda-preset"
	],
	"author": "imexoodeex",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/dreamy-ui/dreamy-ui",
		"directory": "packages/panda-preset"
	},
	"scripts": {
		"build": "tsdown",
		"build:dev": "tsdown",
		"build:production": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit"
	},
	"files": [
		"/dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs"
		}
	},
	"dependencies": {
		"colorjs.io": "^0.5.2",
		"deepmerge": "^4.3.1",
		"react": "^19.2.6"
	},
	"devDependencies": {
		"@pandacss/dev": "^1.11.2",
		"@pandacss/types": "^1.11.2",
		"@types/node": "^22.19.19",
		"@types/react": "^19.2.15",
		"chalk": "^5.4.1",
		"tsdown": "^0.22.4",
		"typescript": "^7.0.2"
	}
}
